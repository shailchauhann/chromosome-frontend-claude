# --- Site ----------------------------------------------------------------
# Public site origin — used by sitemap, OG tags, JSON-LD, canonicals.
NEXT_PUBLIC_SITE_URL=https://chromosome-designs.com

# --- Email (Amazon SES v2) -----------------------------------------------
# AWS region your SES identity is verified in. Common choices:
#   ap-south-1   (Mumbai — closest to studio)
#   us-east-1    (N. Virginia — usually highest SES quota)
AWS_REGION=ap-south-1

# IAM user with the SES SendEmail permission. Use a dedicated user with a
# narrow IAM policy (ses:SendEmail on your verified identity ARNs only).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Where enquiries are delivered.
CONTACT_TO_EMAIL=cavinish@gmail.com
# Sender address — MUST be a verified identity in your SES region.
# Verify the domain (preferred) or a single mailbox in the SES console.
CONTACT_FROM_EMAIL=studio@chromosome-designs.com

# --- Bot protection (Cloudflare Turnstile) -------------------------------
# Get keys at https://dash.cloudflare.com → Turnstile → Add site.
# For local dev, Cloudflare provides "always passes" test keys:
#   site:    1x00000000000000000000AA
#   secret:  1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Analytics (optional) -----------------------------------------------
# Leave empty to skip script injection.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=
